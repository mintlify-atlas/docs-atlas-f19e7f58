  "keyFeatures": [
    "Exports PostgreSQL metrics to Prometheus",
    "20+ built-in collectors for comprehensive monitoring",
    "Multi-target support for monitoring multiple PostgreSQL instances",
    "Configurable authentication modules for secure connections",
    "Docker and Kubernetes deployment ready",
    "Support for PostgreSQL versions 13-18",
    "Custom query support via YAML configuration",
    "Non-superuser operation support"
  ],
  "publicApiSurface": [
    "/metrics endpoint - Main metrics endpoint",
    "/probe endpoint - Multi-target scraping endpoint",
    "collector.database - Database metrics collector",
    "collector.locks - Lock metrics collector",
    "collector.replication - Replication metrics collector",
    "collector.stat_database - Database statistics collector",
    "collector.stat_user_tables - User table statistics collector",
    "collector.wal - Write-Ahead Log metrics collector",
    "collector.stat_statements - pg_stat_statements collector",
    "collector.replication_slot - Replication slot metrics",
    "auth_modules configuration - Authentication modules for multi-target",
    "DATA_SOURCE_NAME - Primary connection string environment variable",
    "--config.file flag - Configuration file path",
    "--web.listen-address flag - HTTP server address",
    "--disable-default-metrics flag - Disable built-in metrics"
  ]
}
